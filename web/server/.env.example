# Used when running the Django backend locally (not via Docker).
# Copy to .env and adjust as needed.

# Django secret key — any random string works for local development
DJANGO_SECRET_KEY=your-secret-key-here

# Enable Django debug mode locally to get detailed error pages
DJANGO_DEBUG=True

# Hosts the dev server responds to
ALLOWED_HOSTS=localhost,127.0.0.1

# Allow both the Vite dev server (:5173) and a local nginx/preview server (:3000)
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
