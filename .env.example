# Used by docker-compose.yml to configure the backend container.
# Copy to .env and fill in real values before running docker compose up.

# Django secret key — must be a long random string in production
DJANGO_SECRET_KEY=change-me

# Set to false in production; true enables the Django debug page
DJANGO_DEBUG=false

# Comma-separated hostnames the backend will serve; add your domain in production
ALLOWED_HOSTS=localhost

# Origins allowed to make cross-site requests to the API (frontend URL)
CORS_ALLOWED_ORIGINS=http://localhost:3000
