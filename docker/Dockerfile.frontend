FROM node:24-alpine AS builder
WORKDIR /app

COPY web/frontend/package*.json web/frontend/.npmrc ./
RUN npm ci

COPY web/frontend/ ./
ENV VITE_API_URL=""
RUN npm run build

FROM nginx:alpine
COPY --from=builder /app/dist /usr/share/nginx/html
COPY web/frontend/nginx.conf /etc/nginx/conf.d/default.conf
