# Platform Mappings
# Use Ubuntu 24.04 specifically to match the host and current GitHub standards
-P ubuntu-latest=ghcr.io/catthehacker/ubuntu:act-24.04
-P ubuntu-24.04=ghcr.io/catthehacker/ubuntu:act-24.04
-P ubuntu-22.04=ghcr.io/catthehacker/ubuntu:act-22.04

# Dependency Caching (actions/cache)
# Enables the internal server that 'actions/cache' talks to.
# Stores dependencies in a local folder on the host machine.
--cache-server-path ~/.cache/actcache

# Action Caching
# Caches the actions themselves (e.g. actions/checkout)
# so act doesn't re-download them from GitHub every run.
--action-cache-path ~/.cache/act

# uv Package Cache
# Mounts the host uv cache into the container.
# uv sync reuses already-downloaded packages — no re-pulling.
--container-options "-v $HOME/.cache/uv:/root/.cache/uv"

# Container Reuse
# Reuses containers between runs instead of recreating them.
# Speeds up reruns during active development.
# --reuse
# --rm=false

# General Settings
# Use .secrets and .env files if they exist
# --secret-file .secrets
# --env-file .env

# Disable images pull if they already exist locally
# Run 'docker pull ghcr.io/catthehacker/ubuntu:act-24.04' manually to refresh
--pull=false
