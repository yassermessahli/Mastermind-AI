# Map runner labels to local Docker images
-P ubuntu-latest=ghcr.io/catthehacker/ubuntu:act-24.04
-P ubuntu-24.04=ghcr.io/catthehacker/ubuntu:act-24.04
-P ubuntu-22.04=ghcr.io/catthehacker/ubuntu:act-22.04

# Local cache server for actions/cache steps
--cache-server-path $HOME/.cache/actcache

# Local disk cache for actions source code (e.g. actions/checkout, actions/setup-python)
--action-cache-path $HOME/.cache/act

# Bind-mount the host uv package cache so uv sync skips re-downloading packages
--container-options --mount=type=bind,source=$HOME/.cache/uv,target=/root/.cache/uv

# reuse containers between runs instead of recreating them (disabled)
# --reuse

# Pass secrets and environment variables from files (disabled)
# --secret-file .secrets
# --env-file .env

# Skip pulling image that already exists locally
--pull=false
